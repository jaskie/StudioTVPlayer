<UserControl x:Class="StudioTVPlayer.View.Main.Recording.RecordingSchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:StudioTVPlayer.View.Main.Recording"
             xmlns:vm="clr-namespace:StudioTVPlayer.ViewModel.Main.Recording"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:RecordingSchedulerViewModel}"
             d:DesignHeight="550" d:DesignWidth="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.SubHeader}">Scheduled recordings</Label>
        <Button Grid.Row="0" Margin="10 10 13 10" FontSize="14" Command="{Binding AddRecordingScheduledItemCommand}" HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal">
                <mah:FontIcon Glyph="&#xE710;"/>
                <TextBlock Margin="5 0 0 0" FontWeight="Normal">Schedule new recording</TextBlock>
            </StackPanel>
        </Button>
        <ListBox Grid.Row="1"
                 Margin="0 0 5 0"
                 Style="{StaticResource ListBoxStyle}"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
            >
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:RecordingSchedulerItemViewModel}">
                    <local:RecordingSchedulerItemView />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <GridSplitter Grid.RowSpan="2" Style="{StaticResource HorizontalGridSplitterStyle}"/>
        <Label Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="{StaticResource MahApps.Font.Size.SubHeader}">Recording history</Label>
        <ListBox Grid.Column="1" Grid.Row="1" Style="{StaticResource ListBoxStyle}" ItemsSource="{Binding RecordingHistory.Recordings}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:RecordingViewModel" >
                    <local:RecordingView/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
